# NeoAgroTech - .gitignore

# Dependencias
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Certificados SSL (no subir certificados privados)
server/cert/*.key
server/cert/*.crt
server/cert/*.pem
!server/cert/.gitkeep

# Variables de entorno
.env
.env.local
.env.*.local

# Logs
logs/
*.log

# Sistema operativo
.DS_Store
Thumbs.db
desktop.ini

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~

# Archivos temporales
*.tmp
*.temp
.cache/

# Build
dist/
build/

# Otros
*.bak
*.backup

